APP_TITLE=Форма задач + Telegram бот
SECRET_KEY=change_me_to_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Qwerty00
BASE_URL=https://your-app.up.railway.app
BOT_TOKEN=123456:your_bot_token
# Необязательно: чат для NOTIFY_ON_NEW (пуш о каждой новой заявке). Команды бота доступны любому пользователю.
ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=change_me_secret
# 1 — long polling с ПК (удобно без ngrok; отключает webhook у бота). На сервере с webhook оставьте 0
TELEGRAM_POLLING=0
# 1 — слать сообщение в Telegram о каждой новой заявке; 0 — только по кнопкам
NOTIFY_ON_NEW=0
TIMEZONE_LABEL=Europe/Vilnius
DB_PATH=/data/tasks.db
